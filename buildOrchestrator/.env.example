# --- OpenRouter (required) ---
OPENROUTER_API_KEY=sk-or-...

# Model that drives the build agent. Any OpenRouter chat model id works.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Agent / build behavior (optional, defaults shown) ---
# Max tokens per model response
MODEL_MAX_TOKENS=4096
# Where repos, logs, and the ledger live (relative to this package)
WORKSPACE_DIR=workspace
# Hard timeout for a single shell command run by the agent (seconds)
COMMAND_TIMEOUT_SECONDS=1800
# How many characters of command output are returned to the agent (full output is always logged to disk)
LOG_TAIL_CHARS=12000
