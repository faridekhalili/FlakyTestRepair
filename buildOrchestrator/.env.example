# --- OpenRouter (required) ---
OPENROUTER_API_KEY=sk-or-...

# Model that drives the build agent. Any OpenRouter chat model id works.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Agent / build behavior (optional, defaults shown) ---
# Max tokens per model response
MODEL_MAX_TOKENS=4096
# Where repos, logs, and the ledger live (relative to this package)
WORKSPACE_DIR=workspace
# Hard timeout for a single shell command run by the agent (seconds)
COMMAND_TIMEOUT_SECONDS=1800
# How many characters of command output are returned to the agent (full output is always logged to disk).
# This is the main context-size (= cost) lever: every returned tail stays in the
# conversation for all subsequent model calls.
LOG_TAIL_CHARS=5000

# --- Per-task cost guards ---
# Wall-clock cap per task; bounds provider-retry death spirals.
# Keep generous — big trees legitimately need 25+ min of Maven time and the
# token/turn caps already bound runaway cost.
TASK_TIMEOUT_MINUTES=45
# Cumulative token cap per task across all model calls (input+output)
TASK_TOKEN_BUDGET=1500000
# Max agent loop turns per task
TASK_MAX_TURNS=40
